# =============================================================================
# VacinaCheck — environment variables
# Copy to .env.local for development; configure in your deployment provider
# for production. NEVER commit real keys.
# =============================================================================

# ---- OpenAI (clinical reconciliation: GPT-5 / GPT-5.1) ----------------------
# Required. Used by app/api/analyze-vaccine/route.js to call the Responses API.
OPENAI_API_KEY=sk-proj-...

# Optional. Set if your key is scoped to a specific OpenAI organization/project.
OPENAI_ORG=
OPENAI_ORGANIZATION=
OPENAI_PROJECT=

# ---- Google Gemini (PDF text extraction) ------------------------------------
# Required for PDF uploads. Image uploads bypass Gemini and go straight to OpenAI.
GEMINI_API_KEY=

# Optional. Override the Gemini model id. Defaults to gemini-3-pro-preview.
GEMINI_MODEL=gemini-3-pro-preview

# ---- API base URL (mobile only) ---------------------------------------------
# Used by lib/api.js when the app runs as a Capacitor iOS bundle and must
# reach the Next.js API over the network instead of via relative paths.
# Leave empty for web.
NEXT_PUBLIC_API_URL=
